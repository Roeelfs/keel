#!/usr/bin/env bash
# Resync runtime skill roots after a branch checkout (skills may have been added/removed).
# $3 == 1 marks a branch checkout; skip file checkouts. Idempotent + safe.
# Activate once per clone: git config core.hooksPath .githooks
[ "${3:-0}" = "1" ] || exit 0
root="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
[ -x "$root/tooling/wire-skills.sh" ] && "$root/tooling/wire-skills.sh" || true
